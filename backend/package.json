{
  "name": "todo-backend",
  "version": "1.0.0",
  "description": "Todo List Backend API with PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --ci --reporters=default --reporters=jest-junit",
    "test:ci": "jest --ci --passWithNoTests --reporters=default",
    "build": "echo 'Backend build complete'"
  },
  "jest": {
    "testEnvironment": "node",
    "reporters": [
      "default",
      ["jest-junit", {
        "outputDirectory": ".",
        "outputName": "junit.xml"
      }]
    ]
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.0.0",
    "jest-junit": "^16.0.0",
    "supertest": "^6.3.3"
  }
}